{
  "name": "@vue-symbols/icons",
  "version": "1.1.0",
  "description": "Symbols icons by Miguel Solorio for Vue.",
  "keywords": [
    "devicons",
    "icons",
    "svg",
    "symbols",
    "vue"
  ],
  "homepage": "https://vue-symbols.dev",
  "bugs": {
    "url": "https://github.com/dahrte/vue-symbols/issues"
  },
  "license": "MIT",
  "author": "dahrte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dahrte/vue-symbols.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./files": "./src/files.ts",
    "./folders": "./src/folders.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./files": "./dist/files/index.js",
      "./folders": "./dist/folders/index.js",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "clean": "git clean -fdX dist node_modules src/runtime/files src/runtime/folders src/files.ts src/folders.ts",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build",
    "release": "bumpp --commit --tag --push"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "bumpp": "11.1.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  }
}
